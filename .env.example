# Razorpay API Keys (Test Mode)
# Replace these with your actual test keys from the Razorpay Dashboard

NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_yourKeyId Here
RAZORPAY_KEY_SECRET=yourKeySecretHere

# Paytm API Keys (Test/Staging Mode)
NEXT_PUBLIC_PAYTM_MID=yourPaytmMidHere
PAYTM_MERCHANT_KEY=yourPaytmMerchantKeyHere
NEXT_PUBLIC_PAYTM_WEBSITE=WEBSTAGING
NEXT_PUBLIC_PAYTM_CHANNEL_ID=WEB
NEXT_PUBLIC_PAYTM_ENV=staging

# PayU India Test Mode Configuration
NEXT_PUBLIC_PAYU_KEY=yourPayuKeyHere
PAYU_MERCHANT_SALT=yourPayuSaltHere
NEXT_PUBLIC_PAYU_ENV=test

# PineLabs Plural Test Mode Configuration
NEXT_PUBLIC_PINELABS_MID=yourPinelabsMidHere
NEXT_PUBLIC_PINELABS_CLIENT_ID=yourPinelabsClientIdHere
PINELABS_CLIENT_SECRET=yourPinelabsClientSecretHere
NEXT_PUBLIC_PINELABS_ENV=test
NEXT_PUBLIC_PINELABS_BASE_URL=https://pluraluat.v2.pinepg.in

# Cashfree Test Mode Configuration
NEXT_PUBLIC_CASHFREE_APP_ID=yourCashfreeAppIdHere
CASHFREE_SECRET_KEY=yourCashfreeSecretKeyHere
NEXT_PUBLIC_CASHFREE_ENV=sandbox

# PhonePe Test Mode Configuration
PHONEPE_CLIENT_ID=yourPhonePeClientIdHere
PHONEPE_CLIENT_SECRET=yourPhonePeClientSecretHere
